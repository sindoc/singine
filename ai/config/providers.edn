;; singine/ai/config/providers.edn
;;
;; Registry of AI providers accessible through the singine governance layer.
;;
;; Rules:
;;   - Credentials are NEVER stored here.  Use :credential/source references.
;;   - This file is git-managed; all changes are auditable.
;;   - To add a provider, add an entry here and create its config file.
;;   - Provider availability is checked with: singine ai status
;;
;; Credential source formats:
;;   "env:VAR_NAME"        — environment variable
;;   "file:~/.singine/auth/{provider}.json"  — local auth file (not git-tracked)
;;   "keystore:{alias}"    — JVM keystore entry
;; ------------------------------------------------------------------

{:providers/registry-version "1.0.0"
