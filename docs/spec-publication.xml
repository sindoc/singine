<?xml version="1.0" encoding="UTF-8"?>
<spec:publication xmlns:spec="https://markupware.com/ns/spec"
                  xml:id="singine-spec"
                  project="singine"
                  title="Singine and SilkPage Technical Specifications"
                  edition="2026-03"
                  owner="MarkupWare"
                  doclet="../core/target/javadoc-xml/doclet.xml"
                  manpages-dir="../man">
  <spec:abstract>
    Singine and SilkPage share a publication-oriented architecture grounded in XML,
    Java, HTTP, and standards-compliant metadata. This manifest drives generated
    reference material from JVM xmldoclet output, manual command specifications,
    curated architectural notes, and reproducible command paths for template
    generation, Logseq-to-Org/XML conversion, and server/snapshot inspection.
  </spec:abstract>

  <spec:project name="singine" homepage="https://singine.markupware.com/" kind="engine">
    <spec:description>
      Singine is an execution engine that governs secure activities across CLI,
      JVM, AI, transport, and publication workflows.
    </spec:description>
    <spec:stack>
      <spec:technology>XML</spec:technology>
      <spec:technology>Java</spec:technology>
      <spec:technology>Rust</spec:technology>
      <spec:technology>Go</spec:technology>
      <spec:technology>C</spec:technology>
      <spec:technology>HTTP</spec:technology>
      <spec:technology>Apache httpd</spec:technology>
      <spec:technology>nginx</spec:technology>
      <spec:technology>dynamic DNS</spec:technology>
      <spec:technology>Node.js</spec:technology>
      <spec:technology>Electron</spec:technology>
      <spec:technology>service workers</spec:technology>
      <spec:technology>Ant</spec:technology>
      <spec:technology>Groovy</spec:technology>
      <spec:technology>Python</spec:technology>
      <spec:technology>Clojure</spec:technology>
    </spec:stack>
  </spec:project>

  <spec:project name="silkpage" homepage="https://silkpage.markupware.com/" kind="publisher">
    <spec:description>
      SilkPage is an XML-first publishing framework whose XSLT and RDF layers
      provide the presentation and metadata model for the generated specifications.
    </spec:description>
  </spec:project>

