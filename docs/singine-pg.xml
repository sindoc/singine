      </varlistentry>
      <varlistentry>
        <term>host</term>
        <listitem><para><literal>127.0.0.1</literal></para></listitem>
      </varlistentry>
      <varlistentry>
        <term>port</term>
        <listitem><para><literal>55432</literal></para></listitem>
      </varlistentry>
      <varlistentry>
        <term>user</term>
        <listitem><para><literal>singine</literal></para></listitem>
      </varlistentry>
      <varlistentry>
        <term>password</term>
        <listitem><para><literal>singine</literal></para></listitem>
      </varlistentry>
    </variablelist>
  </refsect1>
