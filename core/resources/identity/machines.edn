{;; singine machine identity registry
 ;; Managed by: singine cap trust register-ssh
 ;; Every machine has one SSH RSA key pair (minimal trust principle).
 ;; URN scheme: urn:singine:machine:<hostname-slug>:<user>

 :imac-vafa
 {:hostname        "iMacVafa"
  :user            "attar"
  :urn             "urn:singine:machine:imac-vafa:attar"
  :ssh-key-type    "ssh-rsa"
  :ssh-pubkey-file "core/resources/identity/authorized_keys"
  ;; SHA-256 fingerprint of the RSA public key (computed from authorized_keys)
  ;; Run: ssh-keygen -lf authorized_keys -E sha256
  :ssh-fingerprint "TODO:sha256:run-ssh-keygen-lf"
  :registered-at   "2026-02-23"
  :os              "macOS"
  :arch            "x86_64"
  :capabilities    [:mail :broker :kg :sec :render :cli :java :clojure :python]
  :deploy-order    [:mail :broker :kg :checkin]
  ;; Minimal trust: only these aliases needed in singine.jks for this machine
  :required-trust  ["singine-root-ca" "singine-identity-attar"]}

