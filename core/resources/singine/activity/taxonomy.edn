     :activity/shell-init  ["~/.singine/activity.sh"]
     :activity/outputs     [:xml :openapi :sparql :graphql]
     :activity/collibra
     {:collibra/asset-type "Domain"
      :collibra/name       "Electricity Balancing"
      :collibra/id         ""}}]}]}
