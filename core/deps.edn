{:paths ["src" "resources" "classes"]
 :deps  {org.clojure/clojure       {:mvn/version "1.12.0"}
         org.clojure/data.json     {:mvn/version "2.5.1"}
         org.clojure/tools.logging {:mvn/version "1.3.0"}
         org.xerial/sqlite-jdbc    {:mvn/version "3.45.3.0"}

         ;; ── Apache Camel 4.4 LTS — EIP backbone ─────────────────────────────
         ;; camel-core: RouteBuilder, CamelContext, ProducerTemplate, Exchange
         org.apache.camel/camel-core      {:mvn/version "4.4.4"}
         ;; camel-mail: SMTP + IMAP4rev1 consumer/producer (via Jakarta Mail)
         org.apache.camel/camel-mail      {:mvn/version "4.4.4"}
         ;; camel-http: HTTP client producer
         org.apache.camel/camel-http      {:mvn/version "4.4.4"}
         ;; camel-jetty: embedded Jetty HTTP server (consumer for jetty: URIs)
         org.apache.camel/camel-jetty     {:mvn/version "4.4.4"}
         ;; camel-jackson: JSON marshal/unmarshal in routes
         org.apache.camel/camel-jackson   {:mvn/version "4.4.4"}

         ;; ── Jakarta Mail (camel-mail runtime implementation) ─────────────────
         jakarta.mail/jakarta.mail-api    {:mvn/version "2.1.3"}
         org.eclipse.angus/angus-mail     {:mvn/version "2.0.3"}

         ;; ── Apache Commons utilities ──────────────────────────────────────────
         ;; commons-lang3: StringUtils, Base64 (replaces manual Base64 in MailClient.java)
         org.apache.commons/commons-lang3 {:mvn/version "3.14.0"}
         ;; commons-io: IOUtils.toString, FileUtils, FilenameUtils
         commons-io/commons-io            {:mvn/version "2.15.1"}
         ;; commons-codec: DigestUtils SHA-256 (for urfm:File checksum)
         commons-codec/commons-codec      {:mvn/version "1.17.0"}}
 :aliases
 {:run   {:main-opts ["-m" "singine.core.engine"]}
  ;; Start local network server on 0.0.0.0:8080 (Apache Camel + Jetty).
  ;; Connect from iPad/iPhone/Android on same LAN: curl http://<mac-ip>:8080/health
  :serve {:main-opts ["-m" "singine.server.main"]}
  :test {:extra-paths ["test"]
         :extra-deps  {io.github.cognitect-labs/test-runner
                       {:git/tag "v0.5.1"
                        :git/sha "dfb30dd"}}
         :main-opts   ["-m" "cognitect.test-runner"]
         :exec-fn     cognitect.test-runner.api/test}
  :repl {:extra-paths ["test"]
         :main-opts   ["-e" "(require,'singine.consciousness.markov)"
                       "-r"]}
  ;; Compile Java sources into classes/ (must run: clojure -M:javac first).
  ;; The classes/ dir is on :paths so it is always on the classpath.
  :javac {:main-opts ["-e"
                      "(let [src (java.io.File. \"java\")
                             out (doto (java.io.File. \"classes\") .mkdirs)
                             files (filter #(.endsWith (.getName %) \".java\")
                                           (file-seq src))
                             paths (map #(.getAbsolutePath %) files)
                             args  (into-array String (concat [\"-d\" (.getAbsolutePath out)] paths))]
                         (println (str \"Compiling \" (count paths) \" Java source files...\"))
                         (let [rc (com.sun.tools.javac.Main/compile args)]
                           (println (if (zero? rc) \"Done.\" (str \"javac exit: \" rc)))))"
                      ]}}}

