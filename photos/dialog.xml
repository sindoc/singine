<?xml version="1.0" encoding="UTF-8"?>
<!--
  photos/dialog.xml — XML request/response dialog template
  ──────────────────────────────────────────────────────────
  Defines the envelope format for the request/response dialog between
  the two entities (google and apple) in the photo transfer pipeline.

  Each batch produces one <sg:dialog> document containing a paired
  <sg:request> and <sg:response>.  The pipeline.xpl step
  sg:emit-dialog wraps processing results in this envelope.

  XPath queries on a dialog document:
    //sg:request[@entity='google']   — the Google Photos request
    //sg:response[@entity='apple']   — the Apple Photos response
    //sg:item[@status='transferred'] — successfully transferred items
    //sg:item[@status='quarantined'] — compliance-quarantined items
    //sg:compliance-hold             — active compliance holds
    //sg:error                       — any processing errors

  The request-id attribute on <sg:dialog> ties the request to its
  response and corresponds to the batch/@id in dependency-graph.xml.

  This document serves as both a template (copy and fill) and as a
  reference for the XPath expectations of downstream consumers.
-->
<sg:dialog
    xmlns:sg="https://singine.local/photos/1.0"
    xmlns:xs="http://www.w3.org/2001/XMLSchema"
    request-id="b01"
    sprint-id="s01"
    created="2026-03-02T00:00:00Z"
    version="1.0">


  <!-- ══════════════════════════════════════════════════
       REQUEST — sent by entity "google"
       Initiates the batch transfer or processing action.
       ══════════════════════════════════════════════════ -->

  <sg:request
      entity="google"
      batch-id="b01"
      action="export-manifest"
      sent-at="2026-03-02T00:00:00Z">

    <!--
      The entity requesting the action.
      Maps to entities/entity[@id='google'] in dependency-graph.xml.
    -->
    <sg:from>
      <sg:entity-ref id="google" label="Google Photos"/>
      <sg:endpoint>https://photoslibrary.googleapis.com/v1/mediaItems</sg:endpoint>
      <sg:auth-method>oauth2-bearer</sg:auth-method>
    </sg:from>

    <!--
      The entity that should receive and act on this request.
    -->
    <sg:to>
      <sg:entity-ref id="apple" label="Apple Photos"/>
      <sg:endpoint>local://Photos.app/import</sg:endpoint>
      <sg:auth-method>system-keychain</sg:auth-method>
    </sg:to>

    <!--
      Payload: the batch of items being transferred.
      In a real document, <sg:item> elements are generated by
      the pipeline from the Google Photos export.
    -->
    <sg:payload>
      <sg:batch-ref id="b01"/>
      <sg:item-count>0</sg:item-count>
      <!-- Populated by sg:google-export step at runtime -->
      <sg:items/>
    </sg:payload>

    <!--
      Compliance attestation: confirms that all items in the payload
      have passed the compliance screen (step 3 in pipeline.xpl).
    -->
    <sg:compliance-attestation>
      <sg:screened-by>sg:compliance-screen</sg:screened-by>
      <sg:screening-timestamp><!-- set at runtime --></sg:screening-timestamp>
      <sg:quarantined-count>0</sg:quarantined-count>
      <sg:cleared-count>0</sg:cleared-count>
    </sg:compliance-attestation>

  </sg:request>


  <!-- ══════════════════════════════════════════════════
       RESPONSE — returned by entity "apple"
       Confirms receipt and processing outcome.
       ══════════════════════════════════════════════════ -->

  <sg:response
      entity="apple"
      batch-id="b01"
      request-id="b01"
      received-at="<!-- set at runtime -->"
      status="pending">

    <!--
      Summary of items processed.
    -->
    <sg:summary>
      <sg:transferred-count>0</sg:transferred-count>
      <sg:failed-count>0</sg:failed-count>
      <sg:skipped-count>0</sg:skipped-count>
      <sg:quarantined-count>0</sg:quarantined-count>
    </sg:summary>

    <!--
      Per-item results.
      Populated by sg:apple-import and sg:validate steps.

      <sg:item> attributes:
        id         — corresponds to Google Photos media item ID
        status     — transferred | failed | skipped | quarantined
        apple-id   — Apple Photos UUID after import (if transferred)
        hash       — SHA-256 of the transferred file
        reason     — for failed/quarantined items
    -->
    <sg:items/>

    <!--
      Compliance holds: items that could not be transferred due to
      compliance rules.  Referenced in the quarantine report.
    -->
    <sg:compliance-holds/>

    <!--
      Errors: non-fatal processing errors (e.g. transient API failure).
      Fatal errors cause the batch status to become "failed".
    -->
    <sg:errors/>

    <!--
      Updated dependency graph fragment.
      The pipeline uses this to update batch/@status in the master
      dependency-graph.xml after processing.
    -->
    <sg:graph-update>
      <sg:batch-status id="b01" status="done"/>
    </sg:graph-update>

  </sg:response>


</sg:dialog>
